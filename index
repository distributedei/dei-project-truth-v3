        var milestoneFields=["NTP","MC","SC","Interconnection","Witness Test","Performance Test"];

        return <div key={i} className="exec-card">
          <div className="exec-card-head" onClick={function(){setExpanded(isOpen?null:i);}}>
            <div style={{flex:1}}>
              <div style={{display:"flex",alignItems:"center",gap:10}}>
                <div className="exec-proj-name">{p.re||"—"}</div>
                <span className={"exec-cat "+catClass(p.Category)}>{catLabel(p.Category)}</span>
              </div>
              <div className="exec-proj-client">{(p.CLIENT||"").trim()} {p["CITY, STATE"]?("• "+(p["CITY, STATE"]||"").trim()):""} {dc?("• "+dc+" MW DC"):""} {rev?("• "+fmtMoney(rev)):""}</div>
              {p["Critical Path"]&&p["Critical Path"]!=="Done"&&<div style={{marginTop:6,fontSize:11,color:"var(--red)",fontWeight:600}}>⚡ {p["Critical Path"].split("\\n")[0]}</div>}
            </div>
            <div style={{display:"flex",alignItems:"center",gap:12}}>
              {p.Billings&&p.Billings!=="nothing left"&&<div style={{textAlign:"right"}}><div style={{fontSize:10,color:"#8a9baa",textTransform:"uppercase",letterSpacing:0.5}}>Billing</div><div style={{fontSize:12,color:"#779d36",fontWeight:600}}>{p.Billings}</div></div>}
              <span style={{fontSize:16,color:"#c4d0dc",transition:"transform 0.2s",transform:isOpen?"rotate(180deg)":"rotate(0)"}}>▾</span>
            </div>
          </div>

          {isOpen&&<div className="exec-detail">
            <div className="exec-section">
              <div className="exec-section-title">📊 Project Info</div>
              <div className="exec-grid">
                <div className="exec-field"><div className="exec-field-label">Client</div><div className="exec-field-value">{(p.CLIENT||"").trim()||"—"}</div></div>
                <div className="exec-field"><div className="exec-field-label">Project</div><div className="exec-field-value">{p.re||"—"}</div></div>
                <div className="exec-field"><div className="exec-field-label">BD Lead</div><div className="exec-field-value">{(p.BD||"").trim()||"—"}</div></div>
                <div className="exec-field"><div className="exec-field-label">Status</div><div className="exec-field-value">{p.STATUS||"—"}</div></div>
                <div className="exec-field"><div className="exec-field-label">PO Status</div><div className="exec-field-value">{p["PO Status"]||"—"}</div></div>
                <div className="exec-field"><div className="exec-field-label">Location</div><div className="exec-field-value">{p["CITY, STATE"]||"—"}</div></div>
                <div className="exec-field"><div className="exec-field-label">State</div><div className="exec-field-value">{(p.State||"").trim()||"—"}</div></div>
                <div className="exec-field"><div className="exec-field-label">Tracking</div><div className="exec-field-value">{p["TRACKING TYPE"]||"—"}</div></div>
                <div className="exec-field"><div className="exec-field-label">Design</div><div className="exec-field-value">{p.Design||"—"}</div></div>
              </div>
            </div>

            {(p["Owner Contact"]||p["Owner Email"])&&<div className="exec-section">
              <div className="exec-section-title">👤 Owner Contact</div>
              <div className="exec-grid">
                <div className="exec-field"><div className="exec-field-label">Contact</div><div className="exec-field-value">{(p["Owner Contact"]||"").trim()||"—"}</div></div>
                <div className="exec-field"><div className="exec-field-label">Email</div><div className="exec-field-value">{p["Owner Email"]?<a href={"mailto:"+p["Owner Email"]} style={{color:"#779d36",fontSize:12}}>{p["Owner Email"]}</a>:"—"}</div></div>
                {p["Owner Phone"]&&<div className="exec-field"><div className="exec-field-label">Phone</div><div className="exec-field-value">{p["Owner Phone"]}</div></div>}
              </div>
            </div>}

            {(dc||rev)&&<div className="exec-section">
              <div className="exec-section-title">💰 Financials & Capacity</div>
