function ExecRollup(){
  const[search,setSearch]=useState("");
  const[catFilter,setCatFilter]=useState("all");
  const[expanded,setExpanded]=useState(null);
  const[stateFilter,setStateFilter]=useState("all");

  var cats=useMemo(function(){var m={};EXEC_DATA.forEach(function(p){var c=catLabel(p.Category);m[c]=(m[c]||0)+1;});return Object.entries(m).sort(function(a,b){return b[1]-a[1];});},[]);
  var states=useMemo(function(){var m={};EXEC_DATA.forEach(function(p){if(p.State){var s=p.State.trim();m[s]=(m[s]||0)+1;}});return Object.entries(m).sort(function(a,b){return b[1]-a[1];});},[]);

  var filtered=useMemo(function(){return EXEC_DATA.filter(function(p){
    var matchSearch=!search||(p.re||"").toLowerCase().includes(search.toLowerCase())||(p.CLIENT||"").toLowerCase().includes(search.toLowerCase())||(p["CITY, STATE"]||"").toLowerCase().includes(search.toLowerCase());
    var matchCat=catFilter==="all"||catLabel(p.Category)===catFilter;
    var matchState=stateFilter==="all"||(p.State||"").trim()===stateFilter;
    return matchSearch&&matchCat&&matchState;
  });},[search,catFilter,stateFilter]);

  var totalRev=EXEC_DATA.reduce(function(s,p){return s+(p["BID (Revenue)"]||0);},0);
  var activeRev=EXEC_DATA.filter(function(p){var c=(p.Category||"").trim().toLowerCase();return c==="under construction"||c.includes("lntp");}).reduce(function(s,p){return s+(p["BID (Revenue)"]||0);},0);
  var totalMW=EXEC_DATA.reduce(function(s,p){return s+(p["DC SIZE (MW)"]||0);},0);
  var activeCnt=EXEC_DATA.filter(function(p){var c=(p.Category||"").trim().toLowerCase();return c==="under construction";}).length;
  var lntpCnt=EXEC_DATA.filter(function(p){return(p.Category||"").toUpperCase().includes("LNTP");}).length;
  var pipeCnt=EXEC_DATA.filter(function(p){var c=(p.Category||"").trim().toLowerCase();return c==="pipeline"||(!p.Category);}).length;

  return(<div>
    <div className="section-head" style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
