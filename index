      <div style={{display:"flex",gap:8,alignItems:"center"}}><span style={{fontSize:10,color:"#8a9baa",textTransform:"uppercase",letterSpacing:1}}>Source: Excel</span></div>
    </div>

    <div className="exec-kpis">
      <div className="kpi-card good"><div className="kpi-label">Total Projects</div><div className="kpi-value">{EXEC_DATA.length}</div><div className="kpi-sub green">Portfolio</div></div>
      <div className="kpi-card" style={{borderColor:"rgba(46,204,138,0.3)"}}><div className="kpi-label">Active Construction</div><div className="kpi-value">{activeCnt}</div><div className="kpi-sub green">Under construction</div></div>
      <div className="kpi-card"><div className="kpi-label">LNTP</div><div className="kpi-value">{lntpCnt}</div><div className="kpi-sub">Limited notice</div></div>
      <div className="kpi-card"><div className="kpi-label">Pipeline</div><div className="kpi-value">{pipeCnt}</div><div className="kpi-sub">Pre-NTP</div></div>
      <div className="kpi-card"><div className="kpi-label">Total Revenue</div><div className="kpi-value">{fmtMoney(totalRev)}</div><div className="kpi-sub">All projects</div></div>
      <div className="kpi-card"><div className="kpi-label">Active Revenue</div><div className="kpi-value">{fmtMoney(activeRev)}</div><div className="kpi-sub green">Construction + LNTP</div></div>
      <div className="kpi-card"><div className="kpi-label">Total DC MW</div><div className="kpi-value">{totalMW.toFixed(1)}</div><div className="kpi-sub">Portfolio capacity</div></div>
    </div>

    <div className="exec-filters">
      <input className="exec-search" placeholder="Search projects, clients, locations..." value={search} onChange={function(e){setSearch(e.target.value);}}/>
      <div className="ptabs" style={{flex:1,marginBottom:0}}>
        <div className={"ptab "+(catFilter==="all"?"active":"")} onClick={function(){setCatFilter("all");}}>All <span className="tc">({EXEC_DATA.length})</span></div>
        {cats.map(function(e){return <div key={e[0]} className={"ptab "+(catFilter===e[0]?"active":"")} onClick={function(){setCatFilter(catFilter===e[0]?"all":e[0]);}}>{e[0]} <span className="tc">({e[1]})</span></div>;})}
      </div>
    </div>
    {states.length>1&&<div className="pbar" style={{marginBottom:20}}>
      <span style={{fontSize:10,color:"#8a9baa",textTransform:"uppercase",letterSpacing:1,fontWeight:700,marginRight:4}}>State:</span>
      <div className={"pchip "+(stateFilter==="all"?"active":"")} onClick={function(){setStateFilter("all");}}>All</div>
      {states.map(function(e){return <div key={e[0]} className={"pchip "+(stateFilter===e[0]?"active":"")} onClick={function(){setStateFilter(stateFilter===e[0]?"all":e[0]);}}>{e[0]} <span style={{color:"#8a9baa",fontSize:10,marginLeft:3}}>({e[1]})</span></div>;})}
    </div>}

    <div style={{display:"flex",flexDirection:"column",gap:12}}>
      {filtered.map(function(p,i){
        var isOpen=expanded===i;
        var rev=p["BID (Revenue)"];
