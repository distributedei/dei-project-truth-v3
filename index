                {dc&&<div className="exec-field"><div className="exec-field-label">DC Size (MW)</div><div className="exec-field-value" style={{fontFamily:"'Barlow Condensed',sans-serif",fontSize:18,fontWeight:700}}>{dc}</div></div>}
                {ac&&<div className="exec-field"><div className="exec-field-label">AC Size (MW)</div><div className="exec-field-value" style={{fontFamily:"'Barlow Condensed',sans-serif",fontSize:18,fontWeight:700}}>{ac}</div></div>}
                {rev&&<div className="exec-field"><div className="exec-field-label">Revenue (Bid)</div><div className="exec-field-value" style={{fontFamily:"'Barlow Condensed',sans-serif",fontSize:18,fontWeight:700,color:"#779d36"}}>{fmtMoney(rev)}</div></div>}
                {p["BID/WATT"]>0&&<div className="exec-field"><div className="exec-field-label">Bid/Watt</div><div className="exec-field-value">${p["BID/WATT"].toFixed(3)}</div></div>}
                {p["# OF MODULES"]&&<div className="exec-field"><div className="exec-field-label">Modules</div><div className="exec-field-value">{(p["# OF MODULES"]).toLocaleString()}</div></div>}
                {p["MODULE TYPE"]&&<div className="exec-field"><div className="exec-field-label">Module Type</div><div className="exec-field-value">{p["MODULE TYPE"]}</div></div>}
              </div>
            </div>}

            <div className="exec-section">
              <div className="exec-section-title">📅 Milestones</div>
              <div className="exec-grid">
                {milestoneFields.map(function(f){var v=p[f];if(!v)return null;return <div key={f} className="exec-field"><div className="exec-field-label">{f}</div><div className="exec-field-value">{typeof v==="string"&&v.match(/^\d{4}-\d{2}/)?fmtDate(v):v}</div></div>;})}
